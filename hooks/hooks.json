{
  "$schema": "https://raw.githubusercontent.com/anthropics/claude-code/main/schemas/hooks.json",
  "_comment": "Reference layout — install.sh writes the live config into ~/.claude/settings.json. Edit there for runtime; edit here to update the docs/template.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {"type": "command", "command": "python3 \"$HOME/.claude/paarth-safety.py\""}
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {"type": "command", "command": "python3 \"$HOME/.claude/paarth-session-start.py\""}
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Edit|Write|MultiEdit|Read|Grep|Glob",
        "hooks": [
          {"type": "command", "command": "bash \"$HOME/.claude/paarth-tracker.sh\""}
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {"type": "command", "command": "bash \"$HOME/.claude/paarth-distill.sh\" || true"}
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {"type": "command", "command": "python3 \"$HOME/.claude/paarth-prompt-submit.py\""}
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "*",
        "hooks": [
          {"type": "command", "command": "python3 \"$HOME/.claude/paarth-subagent-stop.py\""}
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "*",
        "hooks": [
          {"type": "command", "command": "python3 \"$HOME/.claude/paarth-notification.py\""}
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "Bash",
        "hooks": [
          {"type": "command", "command": "python3 \"$HOME/.claude/paarth-permission.py\""}
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [
          {"type": "command", "command": "python3 \"$HOME/.claude/paarth-precompact.py\""}
        ]
      }
    ]
  }
}
